                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_calendar_week_day6"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/widget_day_cell_bg"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/widget_calendar_week_day6_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_forest_deep"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_calendar_week_day6_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day6_event1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day6_event2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />
            </LinearLayout>
    </LinearLayout>
</LinearLayout>
