<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_calendar_week_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_calendar_week"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/widget_calendar_week_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_week_title"
        android:textColor="@color/widget_forest_deep"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_calendar_week_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/widget_muted"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:weightSum="7">

            <LinearLayout
                android:id="@+id/widget_calendar_week_day0"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/widget_day_cell_bg"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/widget_calendar_week_day0_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_forest_deep"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_calendar_week_day0_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day0_event1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day0_event2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_calendar_week_day1"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/widget_day_cell_bg"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/widget_calendar_week_day1_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_forest_deep"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_calendar_week_day1_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day1_event1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day1_event2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_calendar_week_day2"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/widget_day_cell_bg"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/widget_calendar_week_day2_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_forest_deep"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_calendar_week_day2_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day2_event1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day2_event2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/widget_calendar_week_day3"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/widget_day_cell_bg"
                android:orientation="vertical"
                android:padding="8dp">

                <TextView
                    android:id="@+id/widget_calendar_week_day3_label"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_forest_deep"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_calendar_week_day3_meta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="@color/widget_muted"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day3_event1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@color/widget_forest"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/widget_calendar_week_day3_event2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="2"
