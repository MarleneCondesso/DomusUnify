# Example env for automated tests.
#
# Copy to `.env.test` (ignored by git) if you want to override defaults locally:
#   cp .env.test.example .env.test
#
# Tests will also read these from real environment variables (CI/CD friendly).

DOMUSUNIFY_TEST_PASSWORD="P@ssw0rd123!"

# Used only by the integration tests (we fake Google validation there).
DOMUSUNIFY_TEST_GOOGLE_ID_TOKEN="test.test.test"
DOMUSUNIFY_TEST_GOOGLE_EMAIL="google.user@example.com"
DOMUSUNIFY_TEST_GOOGLE_SUBJECT="google-subject-123"
DOMUSUNIFY_TEST_GOOGLE_NAME="Google User"
DOMUSUNIFY_TEST_GOOGLE_EMAIL_VERIFIED=true
